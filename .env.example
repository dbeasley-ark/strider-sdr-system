# ─── REQUIRED ─────────────────────────────────────────────────────────
# Anthropic — defense-vertical DPA + US-region routing should be
# confirmed before v1 ships (spec §7.7, 7.3.D).
ANTHROPIC_API_KEY=sk-ant-...

# SAM.gov — free tier 10 req/min, 1000/day. Request at:
#   https://open.gsa.gov/api/sam-api-key/
SAM_GOV_API_KEY=...

# Set to true to start the agent without a SAM key (SAM tool returns
# not_found; use web_search / fetch until you have a key).
# SAM_GOV_OPTIONAL=true

# Kill switch (§7.5). Set to `false` to refuse to start.
ARKENSTONE_AGENT_ENABLED=true

# ─── MODEL ────────────────────────────────────────────────────────────
AGENT_MODEL=claude-opus-4-7
# Per assistant turn (includes thinking when enabled). If too low, runs fail
# with stop_reason=max_tokens and halt_reason=max_output_tokens_exhausted.
AGENT_MAX_TOKENS=8192

# ─── BUDGETS (hard rails — spec §1 + §6) ──────────────────────────────
AGENT_MAX_TOOL_CALLS=12
AGENT_MAX_COST_USD=0.50
# Wall clock is checked between LLM rounds; one slow round (large context) can
# still push the total over this. For Opus + heavy web_search, try 120–180.
AGENT_MAX_WALL_SECONDS=90
# When remaining wall drops below this many seconds, inject a one-time user
# nudge to finalize (emit JSON soon).
AGENT_WALL_RESERVE_SECONDS=25
# In the last N seconds of wall budget, disable tools so the model emits JSON.
# Set to 0 to disable.
AGENT_WALL_NO_TOOLS_BUFFER_SECONDS=10
# After max wall is exceeded, one tools-off LLM call turns the transcript into a
# partial Brief (usually low_confidence). Set false to keep the old stub brief.
AGENT_WALL_SYNTHESIS_ENABLED=true
# max_tokens for that synthesis-only call (lower = cheaper/faster).
AGENT_WALL_SYNTHESIS_MAX_TOKENS=4096
# Input tokens for a single API request (usage.input_tokens on the last
# response). Web_search + fetch traces often exceed 40k; 128k matches typical
# Sonnet runs while still catching runaway prompts. Lower for stricter caps.
AGENT_MAX_CONTEXT_TOKENS=128000

# ─── OBSERVABILITY ────────────────────────────────────────────────────
# Per-run artifacts: ./runs/<company-slug>/<ts>/{trace.jsonl,brief.json}
AGENT_RUNS_DIR=./runs
AGENT_LOG_LEVEL=INFO

# Profile: lean | standard | production
AGENT_PROFILE=standard
