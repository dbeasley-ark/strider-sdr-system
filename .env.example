# ─── REQUIRED ─────────────────────────────────────────────────────────
# Anthropic — defense-vertical DPA + US-region routing should be
# confirmed before v1 ships (spec §7.7, 7.3.D).
ANTHROPIC_API_KEY=sk-ant-...

# SAM.gov — free tier 10 req/min, 1000/day. Request at:
#   https://open.gsa.gov/api/sam-api-key/
SAM_GOV_API_KEY=...

# Kill switch (§7.5). Set to `false` to refuse to start.
ARKENSTONE_AGENT_ENABLED=true

# ─── MODEL ────────────────────────────────────────────────────────────
AGENT_MODEL=claude-opus-4-7
AGENT_MAX_TOKENS=4096

# ─── BUDGETS (hard rails — spec §1 + §6) ──────────────────────────────
AGENT_MAX_TOOL_CALLS=12
AGENT_MAX_COST_USD=0.50
AGENT_MAX_WALL_SECONDS=90
AGENT_MAX_CONTEXT_TOKENS=40000

# ─── OBSERVABILITY ────────────────────────────────────────────────────
# Per-run artifacts: ./runs/<company-slug>/<ts>/{trace.jsonl,brief.json}
AGENT_RUNS_DIR=./runs
AGENT_LOG_LEVEL=INFO

# Profile: lean | standard | production
AGENT_PROFILE=standard
